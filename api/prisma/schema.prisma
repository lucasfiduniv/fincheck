// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  phoneNumber String? @map("phone_number")
  notificationsEnabled Boolean @default(false) @map("notifications_enabled")
  notifyDueReminders Boolean @default(true) @map("notify_due_reminders")
  notifyCreditCardDue Boolean @default(true) @map("notify_credit_card_due")
  notifyBudgetAlerts Boolean @default(true) @map("notify_budget_alerts")
  notifyLowBalance Boolean @default(false) @map("notify_low_balance")
  notifyWeeklySummary Boolean @default(false) @map("notify_weekly_summary")

  bankAccounts BankAccount[]
  creditCards CreditCard[]
  creditCardPurchases CreditCardPurchase[]
  creditCardInstallments CreditCardInstallment[]
  categories   Category[]
  transactions Transaction[]
  categoryBudgets CategoryBudget[]
  notificationEvents NotificationEvent[]
  savingsBoxes SavingsBox[]
  savingsBoxCollaborations SavingsBoxCollaborator[]
  savingsBoxTransactions SavingsBoxTransaction[]
  savingsBoxAlerts SavingsBoxAlert[]
  friendshipRequestsSent Friendship[] @relation("FriendshipRequester")
  friendshipRequestsReceived Friendship[] @relation("FriendshipAddressee")
  savingsBoxCollaborationsInvited SavingsBoxCollaborator[] @relation("SavingsBoxCollaboratorInvitedBy")
  vehicles Vehicle[]
  fuelRecords FuelRecord[]
  fuelTripSegments FuelTripSegment[]
  fuelStatsSnapshots FuelStatsSnapshot[]
  vehicleParts VehiclePart[]
  vehicleAuditLogs VehicleAuditLog[]
  vehicleUsageEvents VehicleUsageEvent[]

  @@map("users")
}

enum SavingsBoxStatus {
  ACTIVE
  ARCHIVED

  @@map("savings_box_status")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@map("friendship_status")
}

model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @map("requester_id") @db.Uuid
  addresseeId String           @map("addressee_id") @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

enum SavingsBoxTransactionType {
  DEPOSIT
  WITHDRAW
  YIELD
  ADJUSTMENT

  @@map("savings_box_transaction_type")
}

enum SavingsBoxYieldMode {
  PERCENT
  FIXED

  @@map("savings_box_yield_mode")
}

enum SavingsBoxAlertType {
  GOAL_COMPLETED
  GOAL_NEAR_DUE
  LOW_PROGRESS
  RECURRING_EXECUTED

  @@map("savings_box_alert_type")
}

enum SavingsBoxAlertStatus {
  PENDING
  SENT
  FAILED

  @@map("savings_box_alert_status")
}

model SavingsBox {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  name                String
  description         String?
  status              SavingsBoxStatus @default(ACTIVE)
  currentBalance      Float            @default(0) @map("current_balance")
  targetAmount        Float?           @map("target_amount")
  targetDate          DateTime?        @map("target_date")
  alertEnabled        Boolean          @default(true) @map("alert_enabled")
  recurrenceEnabled   Boolean          @default(false) @map("recurrence_enabled")
  recurrenceDay       Int?             @map("recurrence_day")
  recurrenceAmount    Float?           @map("recurrence_amount")
  lastRecurrenceRunAt DateTime?        @map("last_recurrence_run_at")
  monthlyYieldRate    Float?           @map("monthly_yield_rate")
  yieldMode           SavingsBoxYieldMode? @map("yield_mode")
  lastYieldAppliedAt  DateTime?        @map("last_yield_applied_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborators SavingsBoxCollaborator[]
  transactions SavingsBoxTransaction[]
  alerts       SavingsBoxAlert[]

  @@index([userId, status])
  @@map("savings_boxes")
}

model SavingsBoxCollaborator {
  id              String    @id @default(uuid()) @db.Uuid
  savingsBoxId    String    @map("savings_box_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  invitedByUserId String    @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  savingsBox SavingsBox @relation(fields: [savingsBoxId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User @relation("SavingsBoxCollaboratorInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([savingsBoxId, userId])
  @@index([userId])
  @@map("savings_box_collaborators")
}

model SavingsBoxTransaction {
  id                   String                    @id @default(uuid()) @db.Uuid
  userId               String                    @map("user_id") @db.Uuid
  savingsBoxId         String                    @map("savings_box_id") @db.Uuid
  type                 SavingsBoxTransactionType
  amount               Float
  date                 DateTime
  description          String?
  sourceBankAccountId  String?                   @map("source_bank_account_id") @db.Uuid
  destinationBankAccountId String?               @map("destination_bank_account_id") @db.Uuid
  isAutomatic          Boolean                   @default(false) @map("is_automatic")
  idempotencyKey       String?                   @unique @map("idempotency_key")
  createdAt            DateTime                  @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsBox SavingsBox @relation(fields: [savingsBoxId], references: [id], onDelete: Cascade)

  @@index([userId, savingsBoxId, date])
  @@map("savings_box_transactions")
}

model SavingsBoxAlert {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  savingsBoxId   String               @map("savings_box_id") @db.Uuid
  type           SavingsBoxAlertType
  status         SavingsBoxAlertStatus @default(PENDING)
  message        String
  idempotencyKey String               @unique @map("idempotency_key")
  errorMessage   String?              @map("error_message")
  sentAt         DateTime?            @map("sent_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsBox SavingsBox @relation(fields: [savingsBoxId], references: [id], onDelete: Cascade)

  @@index([userId, savingsBoxId, createdAt])
  @@map("savings_box_alerts")
}

enum NotificationChannel {
  WHATSAPP

  @@map("notification_channel")
}

enum NotificationEventType {
  GENERAL
  DUE_REMINDERS
  CREDIT_CARD_DUE
  BUDGET_ALERTS
  LOW_BALANCE
  WEEKLY_SUMMARY

  @@map("notification_event_type")
}

enum NotificationEventStatus {
  PENDING
  SENT
  FAILED

  @@map("notification_event_status")
}

model NotificationEvent {
  id             String                  @id @default(uuid()) @db.Uuid
  userId         String                  @map("user_id") @db.Uuid
  type           NotificationEventType
  channel        NotificationChannel     @default(WHATSAPP)
  status         NotificationEventStatus @default(PENDING)
  idempotencyKey String                  @unique @map("idempotency_key")
  destination    String
  message        String
  errorMessage   String?                 @map("error_message")
  providerResponse String?               @map("provider_response")
  sentAt         DateTime?               @map("sent_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notification_events")
}

enum BankAccountType {
  CHECKING
  INVESTMENT
  CASH

  @@map("bank_account_type")
}

model BankAccount {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  name           String
  initialBalance Float           @map("initial_balance")
  type           BankAccountType
  color          String
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  transactions Transaction[]
  creditCards CreditCard[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

enum CreditCardPurchaseType {
  ONE_TIME
  INSTALLMENT

  @@map("credit_card_purchase_type")
}

enum CreditCardInstallmentStatus {
  PENDING
  PAID
  CANCELED

  @@map("credit_card_installment_status")
}

model CreditCard {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  bankAccountId String   @map("bank_account_id") @db.Uuid
  name          String
  brand         String?
  color         String
  creditLimit   Float    @map("credit_limit")
  closingDay    Int      @map("closing_day")
  dueDay        Int      @map("due_day")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount      BankAccount             @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  purchases        CreditCardPurchase[]
  installments     CreditCardInstallment[]

  @@map("credit_cards")
}

model CreditCardPurchase {
  id               String                 @id @default(uuid()) @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  creditCardId     String                 @map("credit_card_id") @db.Uuid
  categoryId       String?                @map("category_id") @db.Uuid
  fuelVehicleId    String?                @map("fuel_vehicle_id") @db.Uuid
  fuelOdometer     Float?                 @map("fuel_odometer")
  fuelLiters       Float?                 @map("fuel_liters")
  fuelPricePerLiter Float?                @map("fuel_price_per_liter")
  fuelFillType     FuelFillType           @default(PARTIAL) @map("fuel_fill_type")
  fuelFirstPumpClick Boolean              @default(false) @map("fuel_first_pump_click")
  maintenanceVehicleId String?            @map("maintenance_vehicle_id") @db.Uuid
  maintenanceOdometer Float?              @map("maintenance_odometer")
  description      String
  amount           Float
  purchaseDate     DateTime               @map("purchase_date")
  type             CreditCardPurchaseType
  installmentCount Int                    @default(1) @map("installment_count")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard   CreditCard              @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  category     Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  fuelVehicle  Vehicle?                @relation(fields: [fuelVehicleId], references: [id], onDelete: SetNull)
  maintenanceVehicle Vehicle?          @relation("VehicleMaintenancePurchases", fields: [maintenanceVehicleId], references: [id], onDelete: SetNull)
  installments CreditCardInstallment[]

  @@map("credit_card_purchases")
}

model CreditCardInstallment {
  id                   String                      @id @default(uuid()) @db.Uuid
  userId               String                      @map("user_id") @db.Uuid
  creditCardId         String                      @map("credit_card_id") @db.Uuid
  purchaseId           String                      @map("purchase_id") @db.Uuid
  installmentNumber    Int                         @map("installment_number")
  installmentCount     Int                         @map("installment_count")
  amount               Float
  statementYear        Int                         @map("statement_year")
  statementMonth       Int                         @map("statement_month")
  dueDate              DateTime                    @map("due_date")
  status               CreditCardInstallmentStatus @default(PENDING)
  paymentTransactionId String?                     @map("payment_transaction_id") @db.Uuid
  paidAt               DateTime?                   @map("paid_at")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard         CreditCard        @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  purchase           CreditCardPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  paymentTransaction Transaction?      @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([userId, creditCardId, statementYear, statementMonth])
  @@index([paymentTransactionId])
  @@map("credit_card_installments")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER

  @@map("transaction_type")
}

enum TransactionEntryType {
  SINGLE
  RECURRING
  INSTALLMENT

  @@map("transaction_entry_type")
}

enum TransactionStatus {
  POSTED
  PLANNED

  @@map("transaction_status")
}

model Category {
  id     String          @id @default(uuid()) @db.Uuid
  userId String          @map("user_id") @db.Uuid
  name   String
  icon   String
  type   TransactionType
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  transactions Transaction[]
  creditCardPurchases CreditCardPurchase[]
  categoryBudgets CategoryBudget[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("categories")
}

model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  bankAccountId String          @map("bank_account_id") @db.Uuid
  categoryId    String?         @map("category_id") @db.Uuid
  maintenanceVehicleId String?  @map("maintenance_vehicle_id") @db.Uuid
  maintenanceOdometer Float?    @map("maintenance_odometer")
  name          String
  value         Float
  date          DateTime
  type          TransactionType
  status        TransactionStatus @default(POSTED)
  entryType     TransactionEntryType @default(SINGLE) @map("entry_type")
  recurrenceGroupId String?     @map("recurrence_group_id") @db.Uuid
  installmentNumber Int?        @map("installment_number")
  installmentCount  Int?        @map("installment_count")
  dueDay            Int?        @map("due_day")
  alertDaysBefore   Int?        @map("alert_days_before")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  fuelRecord FuelRecord?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  maintenanceVehicle Vehicle? @relation("VehicleMaintenanceTransactions", fields: [maintenanceVehicleId], references: [id], onDelete: SetNull)
  paidCreditCardInstallments CreditCardInstallment[]

  @@map("transactions")
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  FLEX
  ELECTRIC
  HYBRID

  @@map("fuel_type")
}

enum FuelFillType {
  FULL
  PARTIAL

  @@map("fuel_fill_type")
}

enum FuelSegmentConfidence {
  HIGH
  MEDIUM
  LOW

  @@map("fuel_segment_confidence")
}

model Vehicle {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  name String
  model String?
  plate String?
  photoUrl String? @map("photo_url")
  currentOdometer Float? @map("current_odometer")
  autoOdometerEnabled Boolean @default(false) @map("auto_odometer_enabled")
  averageDailyKm Float? @map("average_daily_km")
  odometerBaseValue Float? @map("odometer_base_value")
  odometerBaseDate DateTime? @map("odometer_base_date")
  fuelType FuelType @default(FLEX) @map("fuel_type")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelRecords FuelRecord[]
  fuelTripSegments FuelTripSegment[]
  fuelStatsSnapshots FuelStatsSnapshot[]
  fuelPurchases CreditCardPurchase[]
  maintenanceTransactions Transaction[] @relation("VehicleMaintenanceTransactions")
  maintenancePurchases CreditCardPurchase[] @relation("VehicleMaintenancePurchases")
  parts VehiclePart[]
  auditLogs VehicleAuditLog[]
  usageEvents VehicleUsageEvent[]

  @@index([userId, createdAt])
  @@map("vehicles")
}

model VehicleAuditLog {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  vehicleId String @map("vehicle_id") @db.Uuid
  eventType String @map("event_type")
  previousValue String? @map("previous_value")
  newValue String? @map("new_value")
  metadata String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, vehicleId, createdAt])
  @@map("vehicle_audit_logs")
}

model VehicleUsageEvent {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  vehicleId String? @map("vehicle_id") @db.Uuid
  eventName String @map("event_name")
  screen String?
  metadata String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([vehicleId, createdAt])
  @@map("vehicle_usage_events")
}

model VehiclePart {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  vehicleId String @map("vehicle_id") @db.Uuid
  name String
  brand String?
  quantity Float @default(1)
  totalCost Float @map("total_cost")
  installedAt DateTime @map("installed_at")
  installedOdometer Float? @map("installed_odometer")
  lifetimeKm Float? @map("lifetime_km")
  nextReplacementOdometer Float? @map("next_replacement_odometer")
  notes String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId, vehicleId, installedAt])
  @@map("vehicle_parts")
}

model FuelRecord {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  vehicleId String @map("vehicle_id") @db.Uuid
  transactionId String @unique @map("transaction_id") @db.Uuid
  odometer Float
  liters Float
  fillType FuelFillType @default(PARTIAL) @map("fill_type")
  firstPumpClick Boolean @default(false) @map("first_pump_click")
  pricePerLiter Float @map("price_per_liter")
  totalCost Float @map("total_cost")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  startSegments FuelTripSegment[] @relation("FuelTripStartRecord")
  endSegments FuelTripSegment[] @relation("FuelTripEndRecord")
  statsSnapshots FuelStatsSnapshot[] @relation("FuelStatsLastRecord")

  @@index([userId, vehicleId, createdAt])
  @@map("fuel_records")
}

model FuelTripSegment {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  vehicleId String @map("vehicle_id") @db.Uuid
  startFuelRecordId String @map("start_fuel_record_id") @db.Uuid
  endFuelRecordId String @map("end_fuel_record_id") @db.Uuid
  startDate DateTime @map("start_date")
  endDate DateTime @map("end_date")
  startOdometer Float @map("start_odometer")
  endOdometer Float @map("end_odometer")
  distanceKm Float @map("distance_km")
  litersConsumed Float @map("liters_consumed")
  totalCost Float @map("total_cost")
  consumptionKmPerLiter Float @map("consumption_km_per_liter")
  costPerKm Float @map("cost_per_km")
  confidence FuelSegmentConfidence @default(MEDIUM)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startFuelRecord FuelRecord @relation("FuelTripStartRecord", fields: [startFuelRecordId], references: [id], onDelete: Cascade)
  endFuelRecord FuelRecord @relation("FuelTripEndRecord", fields: [endFuelRecordId], references: [id], onDelete: Cascade)

  @@index([userId, vehicleId, endDate])
  @@unique([userId, vehicleId, startFuelRecordId, endFuelRecordId])
  @@map("fuel_trip_segments")
}

model FuelStatsSnapshot {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  vehicleId String @map("vehicle_id") @db.Uuid
  month Int
  year Int
  officialConsumptionKmPerLiter Float? @map("official_consumption_km_per_liter")
  officialCostPerKm Float? @map("official_cost_per_km")
  officialDistanceKm Float @default(0) @map("official_distance_km")
  officialLiters Float @default(0) @map("official_liters")
  currentMonthCost Float @default(0) @map("current_month_cost")
  projectedMonthCost Float? @map("projected_month_cost")
  nextRefuelInDays Float? @map("next_refuel_in_days")
  nextRefuelAtKm Float? @map("next_refuel_at_km")
  lastFuelRecordId String? @map("last_fuel_record_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  lastFuelRecord FuelRecord? @relation("FuelStatsLastRecord", fields: [lastFuelRecordId], references: [id], onDelete: SetNull)

  @@index([userId, vehicleId, year, month])
  @@unique([userId, vehicleId, year, month])
  @@map("fuel_stats_snapshots")
}

model CategoryBudget {
  id         String @id @default(uuid()) @db.Uuid
  userId     String @map("user_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  month      Int
  year       Int
  limit      Float
  carryOverEnabled Boolean @default(false) @map("carry_over_enabled")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@map("category_budgets")
}
